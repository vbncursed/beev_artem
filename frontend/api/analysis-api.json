{
  "openapi": "3.0.3",
  "info": {
    "title": "Analysis API",
    "version": "1.0.0"
  },
  "paths": {
    "/api/v1/analyses/{analysisId}": {
      "get": {
        "tags": [
          "AnalysisService"
        ],
        "operationId": "AnalysisService_GetAnalysis",
        "parameters": [
          {
            "name": "analysisId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalysisResponse"
                }
              }
            }
          },
          "default": {
            "description": "Default error response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Status"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/resumes/{resumeId}/analyze": {
      "post": {
        "tags": [
          "AnalysisService"
        ],
        "operationId": "AnalysisService_StartAnalysis",
        "parameters": [
          {
            "name": "resumeId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StartAnalysisRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StartAnalysisResponse"
                }
              }
            }
          },
          "default": {
            "description": "Default error response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Status"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/vacancies/{vacancyId}/candidates": {
      "get": {
        "tags": [
          "AnalysisService"
        ],
        "operationId": "AnalysisService_ListCandidatesByVacancy",
        "parameters": [
          {
            "name": "vacancyId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page.limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "uint32"
            }
          },
          {
            "name": "page.offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "uint32"
            }
          },
          {
            "name": "minScore",
            "in": "query",
            "schema": {
              "type": "number",
              "format": "float"
            }
          },
          {
            "name": "requiredSkill",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "scoreOrder",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "enum"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListCandidatesByVacancyResponse"
                }
              }
            }
          },
          "default": {
            "description": "Default error response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Status"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AIDecision": {
        "type": "object",
        "properties": {
          "hrRecommendation": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "format": "float"
          },
          "hrRationale": {
            "type": "string"
          },
          "candidateFeedback": {
            "type": "string"
          },
          "softSkillsNotes": {
            "type": "string"
          },
          "agentResults": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AgentResult"
            }
          },
          "rawTrace": {
            "type": "string"
          }
        }
      },
      "AgentResult": {
        "type": "object",
        "properties": {
          "agentName": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "structuredJson": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "format": "float"
          }
        }
      },
      "Analysis": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "vacancyId": {
            "type": "string"
          },
          "candidateId": {
            "type": "string"
          },
          "resumeId": {
            "type": "string"
          },
          "vacancyVersion": {
            "type": "integer",
            "format": "uint32"
          },
          "status": {
            "type": "integer",
            "format": "enum"
          },
          "matchScore": {
            "type": "number",
            "format": "float"
          },
          "profile": {
            "$ref": "#/components/schemas/CandidateProfile"
          },
          "breakdown": {
            "$ref": "#/components/schemas/ScoreBreakdown"
          },
          "ai": {
            "$ref": "#/components/schemas/AIDecision"
          },
          "errorMessage": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "AnalysisResponse": {
        "type": "object",
        "properties": {
          "analysis": {
            "$ref": "#/components/schemas/Analysis"
          }
        }
      },
      "CandidateProfile": {
        "type": "object",
        "properties": {
          "skills": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "yearsExperience": {
            "type": "number",
            "format": "float"
          },
          "positions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "technologies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "education": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "summary": {
            "type": "string"
          }
        }
      },
      "CandidateWithAnalysis": {
        "type": "object",
        "properties": {
          "candidateId": {
            "type": "string"
          },
          "fullName": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "matchScore": {
            "type": "number",
            "format": "float"
          },
          "analysisId": {
            "type": "string"
          },
          "analysisStatus": {
            "type": "integer",
            "format": "enum"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "GoogleProtobufAny": {
        "type": "object",
        "properties": {
          "@type": {
            "type": "string",
            "description": "The type of the serialized message."
          }
        },
        "additionalProperties": true,
        "description": "Contains an arbitrary serialized message along with a @type that describes the type of the serialized message."
      },
      "ListCandidatesByVacancyResponse": {
        "type": "object",
        "properties": {
          "candidates": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CandidateWithAnalysis"
            }
          },
          "page": {
            "$ref": "#/components/schemas/PageResponse"
          }
        }
      },
      "PageResponse": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer",
            "format": "uint32"
          },
          "offset": {
            "type": "integer",
            "format": "uint32"
          },
          "total": {
            "type": "string"
          }
        }
      },
      "ScoreBreakdown": {
        "type": "object",
        "properties": {
          "matchedSkills": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "missingSkills": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "extraSkills": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "baseScore": {
            "type": "number",
            "format": "float"
          },
          "mustHavePenalty": {
            "type": "number",
            "format": "float"
          },
          "niceToHaveBonus": {
            "type": "number",
            "format": "float"
          },
          "explanation": {
            "type": "string"
          }
        }
      },
      "StartAnalysisRequest": {
        "type": "object",
        "properties": {
          "resumeId": {
            "type": "string"
          },
          "vacancyId": {
            "type": "string"
          },
          "useLlm": {
            "type": "boolean"
          }
        }
      },
      "StartAnalysisResponse": {
        "type": "object",
        "properties": {
          "analysisId": {
            "type": "string"
          },
          "status": {
            "type": "integer",
            "format": "enum"
          }
        }
      },
      "Status": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "The status code, which should be an enum value of [google.rpc.Code][google.rpc.Code].",
            "format": "int32"
          },
          "message": {
            "type": "string",
            "description": "A developer-facing error message, which should be in English. Any user-facing error message should be localized and sent in the [google.rpc.Status.details][google.rpc.Status.details] field, or localized by the client."
          },
          "details": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GoogleProtobufAny"
            },
            "description": "A list of messages that carry the error details.  There is a common set of message types for APIs to use."
          }
        },
        "description": "The `Status` type defines a logical error model that is suitable for different programming environments, including REST APIs and RPC APIs. It is used by [gRPC](https://github.com/grpc). Each `Status` message contains three pieces of data: error code, error message, and error details. You can find out more about this error model and how to work with it in the [API Design Guide](https://cloud.google.com/apis/design/errors)."
      }
    }
  },
  "tags": [
    {
      "name": "AnalysisService"
    }
  ]
}
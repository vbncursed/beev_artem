APP_ENV=dev

# auth service secrets — required, no defaults in prod.
# Generate with: openssl rand -base64 48
AUTH_JWT_SECRET=replace-me-with-at-least-32-random-bytes-not-this-string

# DB password used by the auth service to connect to postgres.
# Dev: defaults to "admin" in compose to match the local postgres container.
# Prod: must match the real DB user's password (use a secret manager).
AUTH_DB_PASSWORD=admin

# Redis password used by the auth service. Empty for the local redis container.
AUTH_REDIS_PASSWORD=

# Yandex Cloud API key used by the multiagent service to call Foundation
# Models (Responses API). Generate in console.cloud.yandex.ru -> service
# account -> "Create API key". Required — multiagent won't boot without it.
YANDEX_API_KEY=

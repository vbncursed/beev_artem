{
  "swagger": "2.0",
  "info": {
    "title": "Analysis Service API",
    "description": "Resume analysis and candidate scoring service",
    "version": "1.0.0"
  },
  "tags": [
    {
      "name": "AnalysisService"
    }
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/api/v1/analyses/{analysisId}": {
      "get": {
        "operationId": "AnalysisService_GetAnalysis",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1AnalysisResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "analysisId",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "tags": [
          "AnalysisService"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    },
    "/api/v1/resumes/{resumeId}/analyze": {
      "post": {
        "operationId": "AnalysisService_StartAnalysis",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1StartAnalysisResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "resumeId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/AnalysisServiceStartAnalysisBody"
            }
          }
        ],
        "tags": [
          "AnalysisService"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    },
    "/api/v1/vacancies/{vacancyId}/candidates": {
      "get": {
        "operationId": "AnalysisService_ListCandidatesByVacancy",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1ListCandidatesByVacancyResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "vacancyId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "page.limit",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int64"
          },
          {
            "name": "page.offset",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int64"
          },
          {
            "name": "minScore",
            "in": "query",
            "required": false,
            "type": "number",
            "format": "float"
          },
          {
            "name": "requiredSkill",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "scoreOrder",
            "in": "query",
            "required": false,
            "type": "string",
            "enum": [
              "SORT_ORDER_UNSPECIFIED",
              "SORT_ORDER_ASC",
              "SORT_ORDER_DESC"
            ],
            "default": "SORT_ORDER_UNSPECIFIED"
          }
        ],
        "tags": [
          "AnalysisService"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    }
  },
  "definitions": {
    "AnalysisServiceStartAnalysisBody": {
      "type": "object",
      "properties": {
        "vacancyId": {
          "type": "string"
        },
        "useLlm": {
          "type": "boolean"
        }
      }
    },
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    },
    "v1AIDecision": {
      "type": "object",
      "properties": {
        "hrRecommendation": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "format": "float"
        },
        "hrRationale": {
          "type": "string"
        },
        "candidateFeedback": {
          "type": "string"
        },
        "softSkillsNotes": {
          "type": "string"
        },
        "agentResults": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1AgentResult"
          }
        },
        "rawTrace": {
          "type": "string"
        }
      }
    },
    "v1AgentResult": {
      "type": "object",
      "properties": {
        "agentName": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "structuredJson": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "format": "float"
        }
      }
    },
    "v1Analysis": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "vacancyId": {
          "type": "string"
        },
        "candidateId": {
          "type": "string"
        },
        "resumeId": {
          "type": "string"
        },
        "vacancyVersion": {
          "type": "integer",
          "format": "int64"
        },
        "status": {
          "$ref": "#/definitions/v1AnalysisStatus"
        },
        "matchScore": {
          "type": "number",
          "format": "float"
        },
        "profile": {
          "$ref": "#/definitions/v1CandidateProfile"
        },
        "breakdown": {
          "$ref": "#/definitions/v1ScoreBreakdown"
        },
        "ai": {
          "$ref": "#/definitions/v1AIDecision"
        },
        "errorMessage": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "v1AnalysisResponse": {
      "type": "object",
      "properties": {
        "analysis": {
          "$ref": "#/definitions/v1Analysis"
        }
      }
    },
    "v1AnalysisStatus": {
      "type": "string",
      "enum": [
        "ANALYSIS_STATUS_UNSPECIFIED",
        "ANALYSIS_STATUS_QUEUED",
        "ANALYSIS_STATUS_RUNNING",
        "ANALYSIS_STATUS_DONE",
        "ANALYSIS_STATUS_FAILED"
      ],
      "default": "ANALYSIS_STATUS_UNSPECIFIED"
    },
    "v1CandidateProfile": {
      "type": "object",
      "properties": {
        "skills": {
          "type": "array",
          "items": {
            "type": "string"
          }

        "yearsExperience": {
          "type": "number",
          "format": "float"
        },
        "positions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "technologies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "education": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "v1CandidateWithAnalysis": {
      "type": "object",
      "properties": {
        "candidateId": {
          "type": "string"
        },
        "fullName": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "matchScore": {
          "type": "number",
          "format": "float"
        },
        "analysisId": {
          "type": "string"
        },
        "analysisStatus": {
          "$ref": "#/definitions/v1AnalysisStatus"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "v1ListCandidatesByVacancyResponse": {
      "type": "object",
      "properties": {
        "candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1CandidateWithAnalysis"
          }
        },
        "page": {
          "$ref": "#/definitions/v1PageResponse"
        }
      }
    },
    "v1PageRequest": {
      "type": "object",
      "properties": {
        "limit": {
          "type": "integer",
          "format": "int64"
        },
        "offset": {
          "type": "integer",
          "format": "int64"
        }
      }
    },
    "v1PageResponse": {
      "type": "object",
      "properties": {
        "limit": {
          "type": "integer",
          "format": "int64"
        },
        "offset": {
          "type": "integer",
          "format": "int64"
        },
        "total": {
          "type": "string",
          "format": "uint64"
        }
      }
    },
    "v1ScoreBreakdown": {
      "type": "object",
      "properties": {
        "matchedSkills": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missingSkills": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "extraSkills": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "baseScore": {
          "type": "number",
          "format": "float"
        },
        "mustHavePenalty": {
          "type": "number",
          "format": "float"
        },
        "niceToHaveBonus": {
          "type": "number",
          "format": "float"
        },
        "explanation": {
          "type": "string"
        }
      }
    },
    "v1SortOrder": {
      "type": "string",
      "enum": [
        "SORT_ORDER_UNSPECIFIED",
        "SORT_ORDER_ASC",
        "SORT_ORDER_DESC"
      ],
      "default": "SORT_ORDER_UNSPECIFIED"
    },
    "v1StartAnalysisResponse": {
      "type": "object",
      "properties": {
        "analysisId": {
          "type": "string"
        },
        "status": {
          "$ref": "#/definitions/v1AnalysisStatus"
        }
      }
    }
  },
  "securityDefinitions": {
    "BearerAuth": {
      "type": "apiKey",
      "description": "JWT Bearer token. Format: Bearer \u003ctoken\u003e",
      "name": "Authorization",
      "in": "header"
    }
  }
}
